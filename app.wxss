page {
  background-color: #FDFDFD;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.container {
  padding: 60rpx 30rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1A2E;
  display: block;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #5A5A72;
  display: block;
  margin-bottom: 60rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  display: block;
}
