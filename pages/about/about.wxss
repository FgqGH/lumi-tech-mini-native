.hero {
  padding: 100rpx 32rpx 88rpx;
  background: linear-gradient(170deg, #0066CC 0%, #004499 100%);
  text-align: center;
}
.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}
.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.88);
}
.content {
  padding: 40rpx 32rpx;
}
.section {
  margin-bottom: 56rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 24rpx;
  display: block;
  letter-spacing: -0.3rpx;
}
.desc {
  font-size: 28rpx;
  color: #6B6B70;
  line-height: 1.8;
}
.adv-item {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #F0F0F2;
}
.adv-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F0F5FF 0%, #E8EEF8 100%);
  border-radius: 20rpx;
  flex-shrink: 0;
}
.adv-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.adv-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
  margin-bottom: 8rpx;
}
.adv-desc {
  font-size: 25rpx;
  color: #6B6B70;
  line-height: 1.5;
}
.contact-card {
  padding: 36rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 102, 204, 0.1);
  border: 1rpx solid #E8EEF8;
}
.contact-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F2;
}
.contact-item:last-child {
  border-bottom: none;
}
.contact-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F0F5FF;
  border-radius: 16rpx;
}
.contact-text {
  font-size: 28rpx;
  color: #1C1C1E;
}