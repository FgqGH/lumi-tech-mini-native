.hero {
  padding: 100rpx 40rpx 80rpx;
  background: linear-gradient(180deg, #2A5BA8 0%, #1E3D73 100%);
  text-align: center;
}
.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 16rpx;
}
.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}
.content {
  padding: 40rpx 30rpx;
}
.section {
  margin-bottom: 50rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
  display: block;
}
.desc {
  font-size: 27rpx;
  color: #6B7280;
  line-height: 1.8;
}
.adv-item {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.adv-icon {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F0F5FF;
  border-radius: 16rpx;
}
.adv-info {
  flex: 1;
}
.adv-title {
  font-size: 29rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
}
.adv-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}
.contact-card {
  padding: 36rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(42, 91, 168, 0.1);
}
.contact-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F0F0F5;
}
.contact-item:last-child {
  border-bottom: none;
}
.contact-icon {
  font-size: 36rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F0F5FF;
  border-radius: 12rpx;
}
.contact-text {
  font-size: 27rpx;
  color: #1A1A2E;
}