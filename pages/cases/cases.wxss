.hero {
  padding: 60rpx 30rpx;
  background: linear-gradient(180deg, #FDFDFD 0%, #F6F6F8 100%);
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #5A5A72;
}
.content {
  padding: 40rpx 30rpx;
}
.case-card {
  padding: 30rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}
.case-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}
.case-desc {
  font-size: 26rpx;
  color: #5A5A72;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}
.tag {
  padding: 8rpx 16rpx;
  background-color: #F6F6F8;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #2A5BA8;
}