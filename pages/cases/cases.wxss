/* 案例页面样式 - 现代化设计 */
.cases {
  background-color: #F8FAFC;
  min-height: 100vh;
}

/* 顶部区域 */
.hero {
  padding: 70rpx 40rpx 100rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 50%, #047857 100%);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -15%;
  width: 450rpx;
  height: 450rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero .container {
  position: relative;
  z-index: 1;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  line-height: 1.7;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  margin: -40rpx 32rpx 0;
  padding: 36rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(16, 185, 129, 0.2);
  position: relative;
  z-index: 10;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.stat-text {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 内容区域 */
.content {
  padding: 50rpx 32rpx 100rpx;
}

/* 案例卡片 */
.case-card {
  padding: 40rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: none;
  position: relative;
  overflow: hidden;
}

.case-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #10B981 0%, #059669 100%);
}

.case-header {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.case-icon {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  border-radius: 24rpx;
  font-size: 52rpx;
  flex-shrink: 0;
}

.case-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.case-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
  margin-bottom: 12rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: #F1F5F9;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #64748B;
  font-weight: 500;
}

.tag.highlight {
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  color: #059669;
}

.case-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  display: block;
  margin-bottom: 28rpx;
}

/* 案例成果 */
.case-results {
  display: flex;
  gap: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #F1F5F9;
}

.result {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(145deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
}

.result-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #10B981;
}

.result-label {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 8rpx;
}