.hero {
  padding: 64rpx 32rpx;
  background: linear-gradient(170deg, #F5F7FA 0%, #FFFFFF 100%);
  border-bottom: 1rpx solid #E8EAED;
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.3rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #636366;
}
.content {
  padding: 40rpx 32rpx;
}
.case-card {
  padding: 36rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #F0F0F2;
  border-left: 6rpx solid #0066CC;
}
.case-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
  margin-bottom: 16rpx;
}
.case-desc {
  font-size: 26rpx;
  color: #6B6B70;
  line-height: 1.7;
  display: block;
  margin-bottom: 24rpx;
}
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag {
  padding: 10rpx 20rpx;
  background-color: #F0F5FF;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #0066CC;
}