.hero {
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, #F8FAFF 0%, #FFFFFF 100%);
  border-bottom: 1rpx solid #E8EEF8;
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A2E;
  display: block;
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #6B7280;
}
.content {
  padding: 40rpx 30rpx;
}
.case-card {
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border-left: 6rpx solid #2A5BA8;
}
.case-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 16rpx;
}
.case-desc {
  font-size: 25rpx;
  color: #6B7280;
  line-height: 1.7;
  display: block;
  margin-bottom: 20rpx;
}
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag {
  padding: 8rpx 18rpx;
  background-color: #F0F5FF;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #2A5BA8;
}