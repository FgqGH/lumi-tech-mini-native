.hero {
  padding: 60rpx 30rpx;
  background: linear-gradient(180deg, #FDFDFD 0%, #F6F6F8 100%);
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #5A5A72;
}
.content {
  padding: 40rpx 30rpx;
}
.form {
  margin-bottom: 60rpx;
}
.form-group {
  margin-bottom: 30rpx;
}
.label {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}
.input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #E0E0E5;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
  box-sizing: border-box;
}
.textarea {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #E0E0E5;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
  box-sizing: border-box;
  min-height: 200rpx;
}
.btn {
  width: 100%;
  padding: 28rpx;
  background-color: #2A5BA8;
  color: white;
  border-radius: 100rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
}
.info-card {
  padding: 30rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
}
.info-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}
.info-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
}
.info-icon {
  font-size: 32rpx;
}
.info-text {
  font-size: 28rpx;
}