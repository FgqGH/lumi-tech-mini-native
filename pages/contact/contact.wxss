.hero {
  padding: 64rpx 32rpx;
  background: linear-gradient(170deg, #F5F7FA 0%, #FFFFFF 100%);
  border-bottom: 1rpx solid #E8EAED;
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.3rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #636366;
  display: block;
  line-height: 1.6;
}
.content {
  padding: 40rpx 32rpx;
}
.form {
  margin-bottom: 56rpx;
}
.form-group {
  margin-bottom: 28rpx;
}
.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1C1E;
  display: block;
  margin-bottom: 12rpx;
}
.input {
  width: 100%;
  padding: 26rpx 24rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1C1C1E;
  background-color: #FFFFFF;
  box-sizing: border-box;
}
.input::placeholder {
  color: #AEAEB2;
}
.textarea {
  width: 100%;
  padding: 26rpx 24rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1C1C1E;
  background-color: #FFFFFF;
  box-sizing: border-box;
  min-height: 200rpx;
}
.textarea::placeholder {
  color: #AEAEB2;
}
.btn {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, #0066CC 0%, #0052A3 100%);
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 102, 204, 0.28);
}
.btn[disabled] {
  background: linear-gradient(135deg, #AEAEB2 0%, #8E8E93 100%);
  box-shadow: none;
}
.success-msg {
  display: block;
  text-align: center;
  margin-top: 28rpx;
  font-size: 28rpx;
  color: #00A67D;
}
.error-msg {
  display: block;
  text-align: center;
  margin-top: 28rpx;
  font-size: 28rpx;
  color: #FF3B30;
}
.info-card {
  padding: 36rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #F0F0F2;
}
.info-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
  margin-bottom: 28rpx;
}
.info-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F5F5F7;
}
.info-item:last-child {
  border-bottom: none;
}
.info-icon {
  font-size: 40rpx;
}
.info-text {
  font-size: 28rpx;
  color: #1C1C1E;
}