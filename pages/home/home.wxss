.hero {
  padding: 80rpx 40rpx 60rpx;
  background: linear-gradient(180deg, #F8FAFF 0%, #FFFFFF 100%);
  border-bottom: 1rpx solid #E8EEF8;
}
.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1A1A2E;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: -1rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #5A5A72;
  display: block;
  line-height: 1.7;
}
.stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 40rpx 30rpx;
  background-color: #FFFFFF;
  margin: -20rpx 30rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(42, 91, 168, 0.08);
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: #F8FAFF;
  border-radius: 12rpx;
}
.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #2A5BA8;
}
.stat-label {
  font-size: 22rpx;
  color: #8A8A9A;
  margin-top: 8rpx;
  text-align: center;
}
.section {
  padding: 60rpx 30rpx 40rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 30rpx;
  display: block;
}
.service-card {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.service-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F0F5FF;
  border-radius: 16rpx;
}
.service-info {
  flex: 1;
}
.service-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
}
.service-sub {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}
.cta {
  padding: 60rpx 30rpx 80rpx;
  background: linear-gradient(180deg, #F0F5FF 0%, #FFFFFF 100%);
  text-align: center;
}
.cta-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.btn {
  display: inline-block;
  padding: 26rpx 64rpx;
  background-color: #2A5BA8;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(42, 91, 168, 0.3);
}