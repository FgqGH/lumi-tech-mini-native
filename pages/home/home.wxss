.hero {
  padding: 80rpx 30rpx;
  background: linear-gradient(180deg, #FDFDFD 0%, #F6F6F8 100%);
}
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A2E;
  display: block;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #5A5A72;
  display: block;
  line-height: 1.6;
}
.stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40rpx;
  padding: 60rpx 30rpx;
  background-color: #FFFFFF;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2A5BA8;
}
.stat-label {
  font-size: 24rpx;
  color: #8A8A9A;
  margin-top: 8rpx;
}
.section {
  padding: 60rpx 30rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  display: block;
}
.service-card {
  display: flex;
  gap: 24rpx;
  padding: 30rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}
.service-icon {
  font-size: 48rpx;
}
.service-info {
  flex: 1;
}
.service-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}
.service-sub {
  font-size: 24rpx;
  color: #5A5A72;
}
.cta {
  padding: 80rpx 30rpx;
  text-align: center;
  background: linear-gradient(180deg, #F6F6F8 0%, #FDFDFD 100%);
}
.cta-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 40rpx;
}
.btn {
  display: inline-block;
  padding: 24rpx 60rpx;
  background-color: #2A5BA8;
  color: white;
  border-radius: 100rpx;
  font-size: 30rpx;
}