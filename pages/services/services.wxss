.hero {
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, #F8FAFF 0%, #FFFFFF 100%);
  border-bottom: 1rpx solid #E8EEF8;
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A2E;
  display: block;
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #6B7280;
  display: block;
  line-height: 1.6;
}
.content {
  padding: 40rpx 30rpx;
}
.service-card {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.service-icon {
  font-size: 56rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F0F5FF 0%, #E8EEF8 100%);
  border-radius: 20rpx;
}
.service-body {
  flex: 1;
}
.service-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 10rpx;
}
.service-sub {
  font-size: 25rpx;
  color: #6B7280;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}
.features {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.feature {
  padding: 10rpx 18rpx;
  background-color: #F0F5FF;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #2A5BA8;
}