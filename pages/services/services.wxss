.hero {
  padding: 64rpx 32rpx;
  background: linear-gradient(170deg, #F5F7FA 0%, #FFFFFF 100%);
  border-bottom: 1rpx solid #E8EAED;
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.3rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #636366;
  display: block;
  line-height: 1.6;
}
.content {
  padding: 40rpx 32rpx;
}
.service-card {
  display: flex;
  gap: 24rpx;
  padding: 36rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #F0F0F2;
}
.service-icon {
  font-size: 60rpx;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F0F5FF 0%, #E8EEF8 100%);
  border-radius: 24rpx;
  flex-shrink: 0;
}
.service-body {
  flex: 1;
}
.service-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1C1C1E;
  display: block;
  margin-bottom: 12rpx;
}
.service-sub {
  font-size: 26rpx;
  color: #6B6B70;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}
.features {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.feature {
  padding: 10rpx 18rpx;
  background-color: #F5F7FA;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #0066CC;
}